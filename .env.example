BOT_TOKEN=your_telegram_bot_token_here

# SQLite database (path or sqlite://./data/bot.db)
DATABASE_URL=./data/bot.db

# DeepSeek — исправления текста (работает без VPN)
DEEPSEEK_API_KEY=

# OpenAI — Whisper (голос) и TTS (озвучка)
USE_OPENAI=false
# Только Whisper, без TTS (экономит баланс OpenAI):
WHISPER_ENABLED=true
OPENAI_API_KEY=

AUDIO_ROOT=./data/audio
DEFAULT_TIMEZONE=Europe/Moscow
MORNING_DRILL_HOUR=9
MORNING_DRILL_MINUTE=0
EVENING_REMINDER_HOUR=20
EVENING_REMINDER_MINUTE=0
