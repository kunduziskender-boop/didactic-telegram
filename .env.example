BOT_TOKEN=your_telegram_bot_token_here

# SQLite database (path or sqlite://./data/bot.db)
DATABASE_URL=./data/bot.db

# LLM provider: openai | deepseek
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=300

# DeepSeek — fallback LLM if LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=

# British English by default (american to switch)
ENGLISH_VARIANT=british
# gpt-4o-mini-tts нужен для британского акцента (instructions). tts-1 = только US.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# fable — default UK; или ballad, sage. Явно: OPENAI_TTS_VOICE=fable
OPENAI_TTS_VOICE=
# ElevenLabs (optional): если задан ELEVENLABS_API_KEY, голос по ENGLISH_VARIANT
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# Whisper (распознавание голоса)
WHISPER_ENABLED=true
# TTS (озвучка заданий и Shadow) — отдельно от USE_OPENAI
TTS_ENABLED=true
USE_OPENAI=false

# VPN proxy (optional, for OpenAI from RU)
# HTTPS_PROXY=http://127.0.0.1:7890

AUDIO_ROOT=./data/audio
DEFAULT_TIMEZONE=Europe/Moscow
MORNING_DRILL_HOUR=9
MORNING_DRILL_MINUTE=0
EVENING_REMINDER_HOUR=20
EVENING_REMINDER_MINUTE=0
